# ============================================================================
# X-Plosiv Events — Live Voice Agent  ·  ENVIRONMENT VARIABLES
# ----------------------------------------------------------------------------
# Copy to `.env.local` for local dev, and set the SAME vars in Vercel
# (Project → Settings → Environment Variables). NEVER commit real values.
# Every var here is SERVER-SIDE only — none are exposed to the browser
# (no NEXT_PUBLIC_ prefix), so keys never ship in the frontend bundle.
# ============================================================================

# --- Provider selection -----------------------------------------------------
# "vapi" (default, US-hosted, one-call API) | "bolna" (Indian-native: run
# Sarvam voice + Plivo/Exotel telephony via a Bolna agent — lower latency for
# Indian callers, path toward ~₹2/min). Both implement the same interface.
VOICE_PROVIDER=vapi

# --- DEMO MODE (live testing) -----------------------------------------------
# When "1", the frontend "Call my number" tab becomes a plain phone field that
# dials the number you type (E.164-validated + IP rate-limited) with NO OTP —
# so you can call the client's own phone in front of them. Leave UNSET in
# production: the app then only dials allowlisted or OTP-verified numbers.
DEMO_MODE=

# --- Vapi (https://dashboard.vapi.ai) --------------------------------------
# Dashboard → API Keys → copy the PRIVATE key (starts with a UUID).
VAPI_PRIVATE_KEY=your_vapi_private_key_here
# Dashboard → Phone Numbers → import your Twilio number → copy its ID (UUID).
VAPI_PHONE_NUMBER_ID=your_vapi_phone_number_id_here

# --- Bolna (https://platform.bolna.ai) — used when VOICE_PROVIDER=bolna ------
# The Indian-native, lower-latency, lower-cost path. In the Bolna dashboard:
#   1. Create an agent; paste the SAME system prompt from lib/providers/vapi.ts.
#   2. Voice: pick SARVAM (Bulbul V3 — Indian, sub-200ms, Hindi/Hinglish) or
#      Smallest.ai for the most natural "Ria".
#   3. Telephony: attach PLIVO or EXOTEL (Indian, ~₹1/min) — cheaper than Twilio.
#   4. Add post-call extraction fields matching StructuredQualification.
#   5. Copy the agent id + API key below.
#   6. Run `npm run bolna:tune` ONCE — this pushes lib/prompt.ts into the agent
#      AND applies the human-conversation tuning (turn-taking, endpointing,
#      no mid-call drops/silence, backchanneling, ambience). Re-run after any
#      prompt edit. `npm run bolna:tune:dry` previews without writing.
# Cost note: Bolna platform fee (~₹1.7/min) + Sarvam + Plivo ≈ ₹3–5/min. TRUE
# ~₹2/min needs self-hosting (Pipecat/LiveKit + Sarvam + Plivo, no platform
# fee) — see DECISIONS.md.
BOLNA_API_KEY=your_bolna_api_key_here
BOLNA_AGENT_ID=your_bolna_agent_id_here
# Optional: outbound caller number configured in Bolna (E.164).
BOLNA_FROM_NUMBER=
# Optional: override API base (defaults to https://api.bolna.ai).
BOLNA_BASE_URL=
# Optional: shared secret for the completion webhook (/api/bolna-webhook).
# If set, configure the Bolna webhook URL as .../api/bolna-webhook?secret=<value>
# (or send it as an x-webhook-secret header). Unset = webhook accepts unauthenticated.
BOLNA_WEBHOOK_SECRET=

# --- Durable call store (webhook lead capture) ------------------------------
# The completion webhook persists finished calls here so leads survive a closed
# browser tab and are readable across serverless instances. Use a Redis-over-REST
# store (Upstash / Vercel Marketplace). Without these, the app falls back to an
# in-memory Map (local dev only — NOT durable on serverless).
# Vercel Marketplace injects KV_REST_API_URL/TOKEN; Upstash uses UPSTASH_* — both work.
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Optional: how long to retain a captured call (seconds). Default 7 days.
CALL_STORE_TTL_SECONDS=

# --- Voice / model tuning (optional — sensible defaults in code) ------------
# Indian-accent voice is a P0 requirement. Vapi-supported providers here:
#   azure      -> BUNDLED, no extra key. Indian voices:
#                   hi-IN-SwaraNeural  (Hindi/Hinglish — shipped default)
#                   en-IN-NeerjaNeural (Indian English)
#   smallest-ai-> low-latency Indian voices (add a Smallest key in Vapi).
#   11labs     -> bundled; set VOICE_ID to an Indian 11labs voice id.
# NOTE: Sarvam is NOT a Vapi voice provider — it's on the Bolna path only.
VOICE_PROVIDER_NAME=azure
VOICE_ID=hi-IN-SwaraNeural
LLM_MODEL=gpt-4o-mini

# --- ALLOWLIST (the security control) ---------------------------------------
# Comma-separated E.164 numbers this app is ALLOWED to dial. The button dials
# ONLY these. A visitor picks an INDEX into this list — they can never send a
# raw number. Put your own consented phone here for the demo.
ALLOWED_NUMBERS=+919999999999
# Optional friendly labels, comma-separated, same order as ALLOWED_NUMBERS.
ALLOWED_LABELS=Demo lead (my phone)

# --- Twilio Verify (OTP) — enables the "Call my own number" feature ---------
# Lets a visitor prove a number is theirs (SMS one-time code) before the app
# will dial it. Without these three vars the feature stays hidden and only the
# allowlist path is shown. Console → Verify → Services → create one, copy SID.
#   Account SID + Auth Token: Twilio Console dashboard.
#   Verify Service SID: starts with "VA...".
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_VERIFY_SERVICE_SID=your_twilio_verify_service_sid_here

# --- Cost display -----------------------------------------------------------
# USD→INR rate used to show cost per call in rupees.
USD_TO_INR=86
